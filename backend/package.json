{
  "name": "alphanex-ai-trade-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-grade backend for AlphaNex AI Trade investment platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
